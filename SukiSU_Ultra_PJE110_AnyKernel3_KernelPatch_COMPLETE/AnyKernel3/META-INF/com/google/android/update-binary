#!/sbin/sh
# AnyKernel3 Backend
# SukiSU Ultra + KernelPatch for PJE110 (OnePlus Ace 3 / 12R)

SKIPUNZIP=1
OUTFD=$2
ZIPFILE=$3

ui_print() { echo "ui_print $1" >> /proc/self/fd/$OUTFD; }
show_progress() { echo "progress $1 $2" >> /proc/self/fd/$OUTFD; }

AKHOME=/tmp/anykernel
rm -rf "$AKHOME" 2>/dev/null
mkdir -p "$AKHOME"

ui_print " "
ui_print "==================================="
ui_print "   SukiSU Ultra - KernelPatch"
ui_print "   OnePlus Ace 3 / 12R (PJE110)"
ui_print "   Android 16 | Kernel 5.15.180"
ui_print "   Snapdragon 8 Gen 2 (SM8550)"
ui_print "==================================="
ui_print " "

show_progress 0.10 1

cd "$AKHOME"
unzip -o "$ZIPFILE" -d "$AKHOME" >&2

chmod -R 755 "$AKHOME/tools" 2>/dev/null
chmod 755 "$AKHOME/tools/kptools" 2>/dev/null
chmod 755 "$AKHOME/tools/magiskboot" 2>/dev/null
chmod 755 "$AKHOME/tools/busybox" 2>/dev/null

show_progress 0.30 1

. "$AKHOME/anykernel.sh"

show_progress 1.00 1
ui_print " "
ui_print "Flash SukiSU Ultra Manager APK to complete setup."
ui_print " "
